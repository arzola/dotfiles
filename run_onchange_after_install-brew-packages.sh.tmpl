#!/bin/bash
# Auto-runs `brew bundle` on `chezmoi apply` whenever the Brewfile changes.
# The hash below changes with the Brewfile, which forces chezmoi to re-run this.
# Brewfile hash: {{ include "Brewfile" | sha256sum }}
command -v brew >/dev/null 2>&1 || exit 0
echo "==> Brewfile changed — running brew bundle…"
brew bundle --file="$HOME/Brewfile"
