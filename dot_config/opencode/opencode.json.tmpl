{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-8",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "/Users/arzola/.nvm/versions/node/v22.14.0/lib/node_modules/@rynfar/meridian/plugin/meridian.ts"
  ],
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-5.1": {
          "id": "glm-5.1",
          "name": "GLM-5.1",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 204800,
            "output": 131072
          }
        }
      }
    }
  },
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{{ onepasswordRead "op://Private/Z.ai API/credential" }}",
        "Z_AI_MODE": "ZAI"
      }
    },
    "figma": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "40LdZDPJAt4UoJ4tlfn1pB",
        "clientSecret": "{{ onepasswordRead "op://Private/Figma MCP/clientSecret" }}"
      }
    }
  }
}
